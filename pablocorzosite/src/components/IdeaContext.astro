---
/**
 * Module A: "Part of this idea" — understated block near the artifact header
 * naming the central idea the piece advances, linking to the idea page.
 */
import { getSiteGraph } from '../utils/site-graph';

interface Props {
  artifactSlug: string;
}

const { artifactSlug } = Astro.props;
const { artifactsBySlug, ideasBySlug } = await getSiteGraph();

const artifact = artifactsBySlug.get(artifactSlug);
const idea = artifact?.primaryIdea ? ideasBySlug.get(artifact.primaryIdea) : undefined;
---

{
  idea && (
    <aside class="mt-6 border-l-2 border-accent-fill pl-4">
      <p class="t-label text-dim">Part of this idea</p>
      <p class="mt-1.5">
        <a
          href={`/ideas/${idea.slug}`}
          class="t-meta text-foreground! no-underline transition-colors hover:text-accent-text!"
        >
          {idea.title}
        </a>
      </p>
      <p class="t-standfirst mt-1 max-w-[52ch]">{idea.statement}</p>
    </aside>
  )
}
