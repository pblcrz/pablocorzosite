---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import ConnectedContent from '../../components/ConnectedContent.astro';
import IdeaContext from '../../components/IdeaContext.astro';

export const getStaticPaths = (async () => {
  // Drafts render in the local dev server only — never in production builds.
  const pieces = await getCollection('writing', ({ data }) => import.meta.env.DEV || !data.draft);
  return pieces.map((piece) => ({
    params: { slug: piece.id },
    props: { piece },
  }));
}) satisfies GetStaticPaths;

const { piece } = Astro.props;
const { Content } = await render(piece);
const { title, kind, pillar, readTime, number, externalLink, deck } = piece.data;

const linkLabel =
  kind === 'Prototype' ? 'Open' : kind === 'White Paper' ? 'Download PDF' : 'Open';
---

<Base title={`${title} — Pablo Corzo`} description={deck} theme="light">
  <article>
    <header class="shell pt-[46px]">
      <a
        href="/"
        class="t-label inline-block text-dim no-underline transition-colors hover:text-foreground"
      >
        ← Index
      </a>

      <p class="t-label mt-[34px] text-accent-text">
        {kind} / {pillar}
        {
          piece.data.draft && (
            <span class="ml-2 rounded-full bg-accent-fill px-2 py-0.5 text-accent-ink">Draft</span>
          )
        }
      </p>

      <h1 class="t-title font-edo mt-[18px] max-w-[32ch]">{title}</h1>

      <div
        class="mt-8 flex flex-wrap gap-x-9 gap-y-2 border-t border-rule border-b-2 border-b-foreground py-[18px]"
      >
        {
          readTime ? (
            <p class="t-label text-dim">
              <span class="text-muted">{readTime}</span> min read
            </p>
          ) : null
        }
        <p class="t-label text-dim">
          No. <span class="text-muted">{number}</span>
        </p>
      </div>

      {
        externalLink && (
          <a
            href={externalLink}
            rel="noopener noreferrer"
            target="_blank"
            class="t-label mt-6 inline-block rounded-full bg-accent-fill px-5 py-2.5 text-accent-ink no-underline"
          >
            {linkLabel}
          </a>
        )
      }

      <IdeaContext artifactSlug={piece.id} />
    </header>

    <div class="shell">
      <div class="prose-article mx-[15px] pt-12">
        <Content />
      </div>

      <ConnectedContent artifactSlug={piece.id} />
    </div>
  </article>
</Base>
