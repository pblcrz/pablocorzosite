---
// Verification route for the Sanity integration. Renders on demand so newly
// published documents appear without a rebuild. Fold this into /writing once
// you're ready to serve both sources from the same template.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { getPosts } from '../../utils/sanity';

const posts = await getPosts();

const year = (date: string) => new Date(date).getUTCFullYear();
const pad = (n: number) => String(n).padStart(2, '0');
---

<Base title="Pablo Corzo — Writing (Sanity)" theme="dark">
  <section class="shell pt-[52px] pb-[72px]">
    <h1 class="t-display max-w-[14ch]">
      From Sanity<span class="text-accent-text">.</span>
    </h1>
    <p class="t-standfirst mt-6 max-w-[52ch]">
      Live from the Content Lake, rendered on demand.
    </p>
  </section>

  <section class="shell">
    <h2 class="t-label border-b border-rule pb-3">Index</h2>

    {
      posts.length === 0 ? (
        <p class="t-standfirst py-10">
          No documents yet. Publish a Writing entry in the Studio and reload —
          no rebuild required.
        </p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li class="group border-b border-rule">
              <a
                href={`/sanity/${post.slug}`}
                class="grid grid-cols-[auto_1fr] items-baseline gap-x-5 gap-y-2 py-6 no-underline transition-colors duration-150 group-hover:bg-accent-fill md:grid-cols-[3rem_1fr_auto] md:px-4"
              >
                <span class="t-meta group-hover:text-accent-ink">{pad(post.number)}</span>

                <span class="min-w-0">
                  <span class="t-row-title block group-hover:text-accent-ink">{post.title}</span>
                  <span class="t-label mt-2 block group-hover:text-accent-ink">
                    {post.kind} / {post.pillar}
                  </span>
                  <span class="t-standfirst mt-3 block group-hover:text-accent-ink">
                    {post.deck}
                  </span>
                </span>

                <span class="t-meta col-start-2 group-hover:text-accent-ink md:col-start-3">
                  {year(post.published)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
