---
import Base from '../../layouts/Base.astro';
import IdeaCard from '../../components/IdeaCard.astro';
import { getSiteGraph } from '../../utils/site-graph';

const { graph } = await getSiteGraph();

// Newest development first; ideas with no artifacts sink to the end.
const ideas = graph.ideas
  .slice()
  .sort((a, b) => (b.lastArtifactAt ?? '').localeCompare(a.lastArtifactAt ?? ''));
---

<Base
  title="Ideas — Pablo Corzo"
  description="The recurring ideas behind the writing — how they develop, connect, and change across articles, frameworks, white papers, and prototypes."
  theme="dark"
>
  <section class="shell pt-[52px] pb-[52px]">
    <p class="t-label text-accent-text">Ideas</p>
    <h1 class="t-display font-edo mt-[18px] max-w-[22ch]">
      The thinking behind the writing<span class="text-accent-text">.</span>
    </h1>
    <p class="t-standfirst font-ui mt-6 max-w-[64ch]">
      Articles are expressions of ideas. These are the ideas — the claims and observations
      that recur, develop, and challenge one another across everything published here.
    </p>
  </section>

  <section class="shell">
    <h2 class="t-section border-b-2 border-accent-fill pb-4">Active ideas</h2>

    <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {ideas.map((idea) => <IdeaCard idea={idea} />)}
    </div>

    {ideas.length === 0 && <p class="t-standfirst py-10">No ideas published yet.</p>}
  </section>
</Base>
