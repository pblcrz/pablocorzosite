---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { getSiteGraph, monthYear, statusLabels } from '../utils/site-graph';

// Drafts stay visible in the local dev server (labelled below) so they can be
// previewed, but are excluded from production builds.
const pieces = (await getCollection('writing', ({ data }) => import.meta.env.DEV || !data.draft)).sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

// A small set of active ideas — newest development first.
const { graph, artifactsBySlug } = await getSiteGraph();
const featuredIdeas = graph.ideas
  .filter((idea) => idea.artifactCount > 0)
  .sort((a, b) => (b.lastArtifactAt ?? '').localeCompare(a.lastArtifactAt ?? ''))
  .slice(0, 3);
---

<Base title="Pablo Corzo — Writing" theme="dark">
  <section class="shell pt-[52px] pb-[72px]">
    <div>
      <div>
        <h1 class="t-display font-edo max-w-[22ch]">
          Product observations<span class="text-[var(--accent-alt)]">,</span> written down<span
            class="text-accent-text">.</span
          >
        </h1>
        <p class="t-standfirst font-ui mt-6 max-w-[64ch]">
          This is where I share my perspective on product leadership, strategy, operations,
          measurement, and experimentation, drawn from building products and the operating
          systems behind them. I explore the principles, tradeoffs, and organizational
          mechanisms that help teams move more efficient while making better informed
          decisions.
        </p>
      </div>
    </div>
  </section>

  {
    featuredIdeas.length > 0 && (
      <section class="shell pb-16" aria-labelledby="explore-thinking">
        <h2 id="explore-thinking" class="t-label border-b border-rule pb-3">
          Explore the thinking
        </h2>
        <ul>
          {featuredIdeas.map((idea) => {
            const latest = idea.latestArtifact
              ? artifactsBySlug.get(idea.latestArtifact)
              : undefined;
            return (
              <li class="group border-b border-rule">
                <a
                  href={`/ideas/${idea.slug}`}
                  class="block py-6 no-underline transition-colors duration-150 group-hover:bg-accent-fill md:px-4"
                >
                  <span class="t-row-title block group-hover:text-accent-ink">{idea.title}</span>
                  <span class="t-label mt-2 block group-hover:text-accent-ink">
                    {statusLabels[idea.status]}
                    {' · '}
                    {idea.artifactCount} connected {idea.artifactCount === 1 ? 'piece' : 'pieces'}
                  </span>
                  <span class="t-standfirst mt-3 block max-w-[62ch] group-hover:text-accent-ink">
                    {idea.statement}
                  </span>
                  {latest && (
                    <span class="t-label mt-3 block text-dim group-hover:text-accent-ink">
                      Latest development: {latest.title} · {monthYear(latest.published)}
                    </span>
                  )}
                  <span class="t-label mt-3 block text-accent-text group-hover:text-accent-ink">
                    Start here →
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
        <p class="pt-4">
          <a
            href="/ideas"
            class="t-label text-dim no-underline transition-colors hover:text-foreground"
          >
            All ideas →
          </a>
        </p>
      </section>
    )
  }

  <section class="shell">
    <h2 class="t-label border-b border-rule pb-3">Index</h2>

    <ul>
      {
        pieces.map((piece) => (
          <li class="group border-b border-rule">
            <a
              href={`/writing/${piece.id}`}
              class="block py-6 no-underline transition-colors duration-150 group-hover:bg-accent-fill md:px-4"
            >
              <span class="t-row-title block group-hover:text-accent-ink">
                {piece.data.title}
              </span>
              <span class="t-label mt-2 block group-hover:text-accent-ink">
                {piece.data.kind} / {piece.data.pillar}
                {
                  piece.data.draft && (
                    <span class="ml-2 rounded-full bg-accent-fill px-2 py-0.5 text-accent-ink">
                      Draft
                    </span>
                  )
                }
              </span>
              <span class="t-standfirst mt-3 block max-w-[62ch] group-hover:text-accent-ink">
                {piece.data.deck}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    {
      pieces.length === 0 && (
        <p class="t-standfirst py-10">Nothing published yet.</p>
      )
    }
  </section>
</Base>
