---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const pieces = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const year = (date: Date) => date.getUTCFullYear();
const pad = (n: number) => String(n).padStart(2, '0');
---

<Base title="Pablo Corzo — Writing" theme="dark">
  <section class="shell pt-[52px] pb-[72px]">
    <div class="grid gap-12 md:grid-cols-[1.35fr_1fr] md:gap-16">
      <div>
        <h1 class="t-display max-w-[14ch]">
          Product work, written down<span class="text-accent-text">.</span>
        </h1>
        <p class="t-standfirst mt-6 max-w-[52ch]">
          Essays, white papers and prototypes on how product organisations actually
          decide things — and what it costs when they don't.
        </p>
      </div>
    </div>
  </section>

  <section class="shell">
    <h2 class="t-label border-b border-rule pb-3">Index</h2>

    <ul>
      {
        pieces.map((piece) => (
          <li class="group border-b border-rule">
            <a
              href={`/writing/${piece.id}`}
              class="grid grid-cols-[auto_1fr] items-baseline gap-x-5 gap-y-2 py-6 no-underline transition-colors duration-150 group-hover:bg-accent-fill md:grid-cols-[3rem_1fr_auto] md:px-4"
            >
              <span class="t-meta group-hover:text-accent-ink">{pad(piece.data.number)}</span>

              <span class="min-w-0">
                <span class="t-row-title block group-hover:text-accent-ink">
                  {piece.data.title}
                </span>
                <span class="t-label mt-2 block group-hover:text-accent-ink">
                  {piece.data.kind} / {piece.data.pillar}
                </span>
                <span class="t-standfirst mt-3 block max-w-[62ch] group-hover:text-accent-ink">
                  {piece.data.deck}
                </span>
              </span>

              <span class="t-meta col-start-2 group-hover:text-accent-ink md:col-start-3">
                {year(piece.data.published)}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    {
      pieces.length === 0 && (
        <p class="t-standfirst py-10">Nothing published yet.</p>
      )
    }
  </section>
</Base>
