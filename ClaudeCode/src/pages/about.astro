---
import Base from '../layouts/Base.astro';
---

<Base title="About — Pablo Corzo" theme="dark">
  <section class="shell pt-[46px]">
    <p class="t-label text-accent-text">About</p>
    <h1 class="t-title mt-[18px] max-w-[20ch]">
      I came to product through <span class="text-accent-text">industrial engineering.</span>
    </h1>
  </section>

  <div class="shell">
    <div class="prose-article mx-auto max-w-[62ch] pt-12">
      <p>
        Replace this with the real copy. The column is capped at 62 characters
        per line, paragraphs sit 30px apart, and H2s carry a hairline rule above
        them — the same rhythm the article template uses.
      </p>

      <h2>How I work</h2>

      <p>
        No sidebar, no cards, no timeline, no statistics. Prose only.
      </p>
    </div>
  </div>
</Base>
