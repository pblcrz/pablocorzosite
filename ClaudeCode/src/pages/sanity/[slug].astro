---
// Rendered on demand — no getStaticPaths, so new documents resolve immediately.
export const prerender = false;

import { PortableText } from 'astro-portabletext';
import Base from '../../layouts/Base.astro';
import { getPost } from '../../utils/sanity';

const { slug } = Astro.params;
const post = slug ? await getPost(slug) : null;

if (!post) {
  return Astro.redirect('/sanity', 302);
}

const published = new Date(post.published);
const monthYear = published.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
const month = published.toLocaleDateString('en-GB', { month: 'long', timeZone: 'UTC' });

const linkLabel = post.kind === 'White Paper' ? 'Download PDF' : 'Open';
---

<Base title={`${post.title} — Pablo Corzo`} description={post.deck} theme="light">
  <article>
    <header class="shell pt-[46px]">
      <a
        href="/sanity"
        class="t-label inline-block text-dim no-underline transition-colors hover:text-foreground"
      >
        ← Index
      </a>

      <p class="t-label mt-[34px] text-accent-text">{post.kind} / {post.pillar}</p>

      <h1 class="t-title mt-[18px] max-w-[20ch]">{post.title}</h1>

      <div
        class="mt-8 flex flex-wrap gap-x-9 gap-y-2 border-t border-rule border-b-2 border-b-foreground py-[18px]"
      >
        <p class="t-label text-dim">
          <span class="text-muted">{monthYear}</span>
        </p>
        {
          post.readTime ? (
            <p class="t-label text-dim">
              <span class="text-muted">{post.readTime}</span> min read
            </p>
          ) : null
        }
        <p class="t-label text-dim">
          No. <span class="text-muted">{post.number}</span>
        </p>
      </div>

      {
        post.externalLink && (
          <a
            href={post.externalLink}
            rel="noopener noreferrer"
            target="_blank"
            class="t-label mt-6 inline-block rounded-full bg-accent-fill px-5 py-2.5 text-accent-ink no-underline"
          >
            {linkLabel}
          </a>
        )
      }
    </header>

    <div class="shell">
      <div class="prose-article mx-auto max-w-(--container-prose) pt-12">
        {post.body && <PortableText value={post.body} />}
      </div>

      <div class="mx-auto mt-14 max-w-(--container-prose) border-t-2 border-foreground pt-6">
        <p class="t-label text-dim">End · No. {post.number} · {month}</p>
      </div>
    </div>
  </article>
</Base>
